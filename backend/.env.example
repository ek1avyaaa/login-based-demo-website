KEYCLOAK_SERVER=http://127.0.0.1:8080
KEYCLOAK_REALM=your-realm
KEYCLOAK_CLIENT_ID=secure-access-portal
KEYCLOAK_CLIENT_SECRET=replace-with-keycloak-client-secret

# Dedicated service account used only for Keycloak user lookup, creation, and
# this portal's client-role mappings. Do not use a human administrator password.
KEYCLOAK_MANAGEMENT_CLIENT_ID=portal-user-manager
KEYCLOAK_MANAGEMENT_CLIENT_SECRET=replace-with-management-client-secret
KEYCLOAK_ACCESS_ROLE=portal_access

# Must match a Keycloak Valid Redirect URI exactly.
OIDC_REDIRECT_URI=http://localhost:8000/api/auth/sso/callback
FRONTEND_URL=http://localhost:5173

# Use a long random value. This signs the short-lived OAuth state cookie.
OIDC_SESSION_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=false
